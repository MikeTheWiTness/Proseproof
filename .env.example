# ============================================================
# Proseproof 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
#
# 两种配置方式（按优先级）：
#   1. CLI 参数：  proseproof run input.md --api-url ... --api-key ...
#   2. 环境变量：  下方 PROSEPROOF_* 变量
#   3. Profile .env：profiles/<name>/.env（独立于项目根 .env）
# ============================================================

# ---- LLM API 配置（必填） ----
# 支持任意 OpenAI 兼容 API（DeepSeek、Qwen、GLM、本地 vLLM 等）

# API 端点地址（需包含完整路径）
PROSEPROOF_API_URL=https://api.deepseek.com/v1/chat/completions

# API 密钥
PROSEPROOF_API_KEY=sk-your-api-key-here

# 模型名称
PROSEPROOF_MODEL=deepseek-chat

# ---- PDF 编译（可选） ----
# 如果 xelatex 不在系统 PATH 中，可以指定绝对路径
# XELATEX_PATH=/usr/bin/xelatex
